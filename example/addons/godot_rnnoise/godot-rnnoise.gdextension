[configuration]

entry_symbol = "godot_rnnoise_library_init"
compatibility_minimum = "4.3"

[libraries]

macos.debug = "res://addons/godot_rnnoise/bin/libgodot_rnnoise.macos.template_debug.framework"
macos.release = "res://addons/godot_rnnoise/bin/libgodot_rnnoise.macos.template_release.framework"
windows.debug.x86_64 = "res://addons/godot_rnnoise/bin/libgodot_rnnoise.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://addons/godot_rnnoise/bin/libgodot_rnnoise.windows.template_release.x86_64.dll"
linux.debug.x86_64 = "res://addons/godot_rnnoise/bin/libgodot_rnnoise.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://addons/godot_rnnoise/bin/libgodot_rnnoise.linux.template_release.x86_64.so"
